{
  "publish": {
    "projects": {
      "homepage": {
        "baseDir": ".",
        "outDir": "./docs",
        "include": [
          "index.org",
          "posts/**/*.org"
        ],
        "ignore": [
          ".git/**"
        ],
        "recursive": true,
        "rewriteFileLinks": true,
        "includeDefaultStyle": false,
        "postambleHtml": "<div id=\"postamble\" class=\"status\"><p class=\"postamble\">\u00a9\ufe0f Avi Press 2026</p><p class=\"postamble\"><a href=\"https://twitter.com/avi_press\">Twitter</a> <a href=\"https://github.com/aviaviavi\">GitHub</a> <a href=\"https://www.linkedin.com/in/avi-press-4437a356\">LinkedIn</a> <a href=\"https://bsky.app/profile/avi.press\">Bluesky</a></p></div>",
        "assets": {
          "include": [
            "CNAME",
            "css/**",
            "js/**",
            "images/**",
            ".well-known/**"
          ],
          "ignore": [
            "**/.DS_Store"
          ]
        },
        "index": {
          "file": "sitemap.html",
          "title": "Sitemap for project homepage-content"
        },
        "sitemapXml": {
          "file": "sitemap.xml",
          "baseUrl": "https://avi.press",
          "includeIndexPage": true
        }
      }
    }
  }
}